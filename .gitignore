*.so
*.o

# ── Model weights & checkpoints (download / retrain instead) ─────────────
*.pt
*.pth
checkpoints/
pretrained_models/

# ── Generated data & experiment outputs ──────────────────────────────────
*.npz
*.nii
*.nii.gz
*.lmdb
lmdb_cache/
*_LMDB_cache/
runs/
exp_log/
*.log
postprocessing_logs.csv

